{
	"name": "markdown-image-converter",
	"displayName": "Markdown Image Converter",
	"description": "Convert Markdown files to images (PNG/JPEG) directly in VS Code",
	"publisher": "ryuya",
	"license": "MIT",
	"icon": "images/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/3ru/markdown-image-converter"
	},
	"packageManager": "pnpm@10.15.1",
	"version": "0.0.4",
	"engines": {
		"vscode": "^1.80.0"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"vscode-extension",
		"markdown",
		"image-converter",
		"markdown-to-image",
		"png",
		"jpeg",
		"documentation",
		"screenshot",
		"content-creation",
		"visual-studio-code",
		"developer-tools",
		"productivity",
		"export",
		"converter",
		"image-generator",
		"markdown-tools",
		"writing",
		"blogging",
		"social-media",
		"zenn"
	],
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "markdown-image-converter.exportPNG",
				"title": "Markdown Image Converter: Export (png)"
			},
			{
				"command": "markdown-image-converter.exportJPEG",
				"title": "Markdown Image Converter: Export (jpeg)"
			}
		],
		"configuration": {
			"title": "Markdown Image Converter",
			"properties": {
				"markdown-image-converter.executablePath": {
					"type": "string",
					"default": "",
					"description": "Chrome/Chromium executable path. If empty, the default Chrome installation path will be used."
				},
				"markdown-image-converter.splitter": {
					"type": "string",
					"default": "",
					"description": "Splitter string to divide markdown into multiple images"
				},
				"markdown-image-converter.outputFormat": {
					"type": "string",
					"enum": [
						"png",
						"jpeg"
					],
					"default": "png",
					"description": "Default output format"
				},
				"markdown-image-converter.resolution": {
					"type": "string",
					"enum": [
						"standard",
						"hd"
					],
					"default": "hd",
					"description": "Image resolution quality (standard: 1x, hd: 2x)"
				},
				"markdown-image-converter.splitOutputDir": {
					"type": "string",
					"default": "{name}-{format}",
					"description": "Output directory pattern for split images. Default: filename-format (e.g., example-png)"
				},
				"markdown-image-converter.margin": {
					"type": "number",
					"minimum": 0,
					"default": 12,
					"description": "Margin around the edges of the exported image, in pixels."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "pnpm run package",
		"compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
		"compile-tests": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\" && tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
		"check-types": "tsc --noEmit",
		"lint": "biome check ./src",
		"format": "biome format ./src esbuild.js tsconfig.json biome.json --write",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/mocha": "^10.0.10",
		"@types/node": "~20.17.17",
		"@types/sinon": "^17.0.3",
		"@types/vscode": "^1.80.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.4.1",
		"@vscode/vsce": "3.7.1",
		"esbuild": "^0.27.4",
		"npm-run-all": "^4.1.5",
		"sinon": "^21.0.3",
		"typescript": "^5.7.3"
	},
	"dependencies": {
		"katex": "0.16.44",
		"mermaid": "11.13.0",
		"node-html-parser": "7.0.1",
		"puppeteer": "^24.40.0",
		"puppeteer-core": "^24.40.0",
		"zenn-content-css": "^0.1.158",
		"zenn-markdown-html": "^0.1.158"
	},
	"pnpm": {
		"overrides": {
			"basic-ftp": "5.2.0",
			"brace-expansion@1": "1.1.13",
			"brace-expansion@2": "2.0.3",
			"diff": "8.0.4",
			"glob@10": "10.5.0",
			"js-yaml": "4.1.1",
			"minimatch@3": "3.1.5",
			"minimatch@9": "9.0.9",
			"picomatch": "2.3.2",
			"prismjs": "1.30.0",
			"serialize-javascript": "7.0.5"
		}
	}
}
